{
    "name": "templite/cms",
    "description": "Templite CMS Core - Block-based CMS for Laravel",
    "type": "library",
    "keywords": ["cms", "laravel", "blocks", "vue", "templates"],
    "license": "MIT",
    "authors": [
        {
            "name": "Templite Team",
            "email": "dev@templite.ru"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "laravel/sanctum": "^4.0",
        "intervention/image": "^3.0",
        "spatie/laravel-image-optimizer": "^1.8",
        "darkaonline/l5-swagger": "^8.5",
        "scssphp/scssphp": "^1.12",
        "enshrined/svg-sanitize": "^0.22",
        "pragmarx/google2fa-laravel": "^2.0",
        "bacon/bacon-qr-code": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Templite\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Templite\\Cms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Templite\\Cms\\CmsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
